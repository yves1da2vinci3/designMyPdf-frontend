# Variables publiques Firebase (console Firebase > Paramètres du projet > Votre appli Web)

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optionnel : URL du handler OAuth (défaut : domaine Firebase + __/auth/handler)
# NEXT_PUBLIC_FIREBASE_AUTH_HANDLER_URL=https://votre-projet.firebaseapp.com/__/auth/handler

# API backend (crédits IA, auth)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:63293/api

# Anthropic
# ANTHROPIC_API_KEY=

# Modèles IA — TEXT = édition / sans image ; VISION = maquette → HTML (image jointe)
# Défauts code : Haiku 4.5 (texte), Sonnet 4 (vision). 1000 crédits/mois ≈ 1 $ API max/utilisateur.
# AI_MODEL_TEXT=claude-haiku-4-5-20251001
# AI_MODEL_VISION=claude-sonnet-4-20250514
